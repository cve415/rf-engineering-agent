# 1. LLM Provider (OpenRouter is recommended for Model Shootouts)
OPENROUTER_API_KEY=your_openrouter_key_here

# 2. Specific Model Overrides (Optional)
# Default is set to moonshotai/kimi-k2.6 or anthropic/claude-3.5-sonnet
PRIMARY_MODEL=moonshotai/kimi-k2.6

# 3. Infrastructure & MCP (For Friday's integration)
GITHUB_PERSONAL_ACCESS_TOKEN=your_github_pat_here
BASE_HARNESS_PATH=../core-harness

# 4. Search & Signals (If applicable)
SERPAPI_API_KEY=your_search_key_here
